+body {
+    font-family: sans-serif;
+    margin: 20px;
+}
+
+.controls, .stats {
+    margin-bottom: 20px;
+    padding: 10px;
+    background-color: #f0f0f0;
+    border-radius: 5px;
+}
+
+.controls button, .controls input {
+    margin-right: 10px;
+}
+
+#viz-container {
+    display: flex;
+    flex-direction: column;
+    align-items: center;
+    margin-top: 20px;
+    width: 100%;
+}
+
+#main-array-container {
+    margin-bottom: 40px;
+    display: flex;
+    justify-content: center;
+    flex-wrap: wrap;
+    gap: 10px;
+    min-height: 50px;
+}
+
+.array-element {
+    display: flex;
+    justify-content: center;
+    align-items: center;
+    width: 40px;
+    height: 40px;
+    border: 1px solid #ccc;
+    border-radius: 4px;
+    background-color: #e0e0e0;
+    font-weight: bold;
+    font-size: 14px;
+    transition: all 0.3s ease;
+}
+
+.array-element.highlight {
+    background-color: #ffeb3b;
+    transform: scale(1.1);
+    border-color: #fbc02d;
+}
+
+.array-element.sorted {
+    background-color: #4caf50;
+    color: white;
+    border-color: #388e3c;
+}
+
+#buckets-container {
+    display: flex;
+    justify-content: center;
+    gap: 20px;
+    width: 100%;
+    flex-wrap: wrap;
+}
+
+.bucket {
+    display: flex;
+    flex-direction: column;
+    align-items: center;
+    width: 60px;
+    min-height: 100px;
+    border: 2px solid #2196f3;
+    border-top: none;
+    border-radius: 0 0 5px 5px;
+    padding: 5px;
+    background-color: #f8fcf8;
+}
+
+.bucket-label {
+    margin-top: 5px;
+    font-weight: bold;
+    color: #2196f3;
+}
+
+.bucket-items {
+    display: flex;
+    flex-direction: column-reverse;
+    gap: 5px;
+    width: 100%;
+    min-height: 50px;
+}
+
+.bucket-item {
+    display: flex;
+    justify-content: center;
+    align-items: center;
+    width: 100%;
+    height: 30px;
+    background-color: #bbdefb;
+    border: 1px solid #90caf9;
+    border-radius: 3px;
+    font-size: 12px;
+    transition: all 0.3s ease;
+}
+
+.digit-highlight {
+    color: #e91e63;
+    font-weight: 900;
+    text-decoration: underline;
+}
